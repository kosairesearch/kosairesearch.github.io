# ── X 멘션 자동응답 봇 · 환경변수 (Vercel 프로젝트 Settings > Environment Variables) ──
# 값은 절대 깃에 커밋하지 말 것. Vercel 대시보드에만 입력.

# 필수 — 서술 생성(이미 보유)
ANTHROPIC_API_KEY=
NEWS_MODEL=claude-sonnet-4-6          # 선택(기본값 있음)

# 필수 — 멘션 감지(Apify, 이미 보유)
APIFY_TOKEN=
BOT_HANDLE=kosai_x                    # @ 없이 봇 계정 핸들

# 필수 — 답글 게시(X 개발자앱, Read+Write)
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# 필수 — 저장소(Upstash Redis · REST)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# 필수 — 자기연쇄/크론 보호
APP_URL=                             # 배포 후 부여되는 https://<프로젝트>.vercel.app
POLL_SECRET=                         # 아무 긴 랜덤 문자열(크론·엔드포인트 보호)

# 선택 — 최근 공시(DART, 이미 보유). 없으면 웹서치로 대체
DART_API_KEY=

# 선택 — 기본값 있음
DATA_BASE=https://kosai.kr/data      # 실시간 지표 소스(kosai.kr 일일 데이터)
CACHE_STALE_MONTHS=3                 # 서술 캐시 N개월 지나면 재생성
WEB_SEARCH_MAX=5
