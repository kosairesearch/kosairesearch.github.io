# X 앱 키 (developer.x.com → 앱 → Keys and tokens)
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
X_BOT_HANDLE=kosai_x

# webhook.js → process.py 내부 호출 인증 (아무 랜덤 문자열)
INTERNAL_SECRET=

# Upstash Redis (콘솔 → 데이터베이스 → REST API 탭)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# 기존 KOSAI에서 쓰던 키 재사용
ANTHROPIC_API_KEY=
DART_API_KEY=

# 설명 캐시 유효기간(일)
CACHE_TTL_DAYS=90
